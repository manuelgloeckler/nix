{
  "mcpServers": {
    "github": {
      "type": "stdio",
      "command": "/bin/sh",
      "args": [
        "-lc",
        "GITHUB_PERSONAL_ACCESS_TOKEN=\"$(gh auth token 2>/dev/null)\" exec github-mcp-server stdio"
      ]
    },
    "github-readonly": {
      "type": "stdio",
      "command": "/bin/sh",
      "args": [
        "-lc",
        "GITHUB_PERSONAL_ACCESS_TOKEN=\"$(gh auth token 2>/dev/null)\" exec github-mcp-server stdio --read-only"
      ]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "grep": {
      "type": "http",
      "url": "https://mcp.grep.app"
    },
    "uv-mcp": {
      "type": "stdio",
      "command": "uv-mcp"
    }
  }
}
