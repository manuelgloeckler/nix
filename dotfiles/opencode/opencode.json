{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/.config/opencode/system-prompt.md"
  ],
  "plugin": [
    "opencode-claude-auth",
    "opencode-anthropic-auth@0.0.13",
    "@zenobius/opencode-skillful",
    "opencode-pollinations-plugin",
    "@bdliyq/opencode-rate-limit-retry@latest"
  ],
  "permission": {
    "external_directory": "allow",
    "bash": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow"
  },
  "mcp": {
    "github": {
      "type": "local",
      "command": [
        "/bin/sh",
        "-lc",
        "GITHUB_PERSONAL_ACCESS_TOKEN=\"$(gh auth token 2>/dev/null)\" exec github-mcp-server stdio"
      ]
    },
    "github-readonly": {
      "type": "local",
      "command": [
        "/bin/sh",
        "-lc",
        "GITHUB_PERSONAL_ACCESS_TOKEN=\"$(gh auth token 2>/dev/null)\" exec github-mcp-server stdio --read-only"
      ]
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "uv-mcp": {
      "type": "local",
      "command": [
        "/Users/manug/.local/bin/uv-mcp"
      ]
    }
  }
}
