{
  "$schema": "https://opencode.ai/config.json",
  "theme": "ayu-dark",
  "instructions": [
    "~/.config/opencode/system-prompt.md"
  ],
  "plugin": [
    "opencode-claude-auth",
    "@zenobius/opencode-skillful"
  ],
  "permission": {
    "external_directory": "allow",
    "bash": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  }
}
